# TalkingToad — Environment Variables
# Copy to .env (backend) or .env-ttoad (custom settings)
# Never commit .env files to source control

# ── Auth ──────────────────────────────────────────────────────────────────────

# Bearer token protecting the crawl endpoints (leave blank to disable auth in dev)
AUTH_TOKEN=

# ── Data store ────────────────────────────────────────────────────────────────

# Production (Vercel): set both of these from your Upstash Redis console
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# Development: SQLite file (ignored when Upstash vars are set)
DATABASE_URL=sqlite:///./talkingtoad.db

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins (no wildcards in prod)
ALLOWED_ORIGINS=http://localhost:5173

# ── Crawler ───────────────────────────────────────────────────────────────────

CRAWLER_USER_AGENT=NonprofitCrawler/1.0 (+https://github.com/dbgnvan2/talkingtoad)
MAX_PAGES_PER_CRAWL=500
CRAWL_REQUEST_TIMEOUT_S=5

# ── Logging ───────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO

# ── Rate limiting ─────────────────────────────────────────────────────────────

RATE_LIMIT_ENABLED=true

# ── Data retention ────────────────────────────────────────────────────────────

RESULT_TTL_DAYS=7

# ── AI Analysis (v1.7+) ───────────────────────────────────────────────────────

# Provide at least one of these to enable AI analysis and remediation.
# If both are provided, Gemini is used by default.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Testing value for verification (can be in .env-ttoad)
API_KEY_READ=

# ── Frontend (frontend/.env.local) ────────────────────────────────────────────

# Auth token must match AUTH_TOKEN above (omit if AUTH_TOKEN is blank)
# VITE_AUTH_TOKEN=
